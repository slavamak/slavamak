{
  "name": "slavamak",
  "version": "6.0.0-alpha",
  "description": "My website",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/slavamak/slavamak.git"
  },
  "homepage": "https://github.com/slavamak/slavamak#readme",
  "author": "Slava Maksimov <hello@slavamak.com> (https://slavamak.com)",
  "scripts": {
    "format": "prettier --write .",
    "lint:scripts": "eslint \"**/*.{ts,tsx}\" --fix",
    "lint:styles": "stylelint \"**/*.css\" --fix",
    "prepare": "husky install && husky add .husky/pre-commit \"pnpm lint-staged\""
  },
  "lint-staged": {
    "*.{ts,tsx}": "pnpm lint:scripts",
    "*.{css}": "pnpm lint:styles",
    "*.{ts,tsx,css}": "pnpm format"
  },
  "browserslist": {
    "production": [
      "last 2 version",
      "firefox >= 75",
      "chrome >= 79",
      "edge >= 79",
      "safari >= 12"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "devDependencies": {
    "eslint": "^8.40.0",
    "eslint-config-prettier": "^8.8.0",
    "eslint-plugin-import": "^2.27.5",
    "eslint-plugin-jsx-a11y": "^6.7.1",
    "eslint-plugin-prettier": "^4.2.1",
    "eslint-plugin-simple-import-sort": "^10.0.0",
    "husky": "^8.0.3",
    "lint-staged": "^13.2.2",
    "prettier": "^2.8.8",
    "prettier-plugin-tailwindcss": "^0.2.8",
    "stylelint": "^15.6.1",
    "stylelint-config-prettier": "^9.0.5",
    "stylelint-prettier": "^3.0.0"
  }
}
